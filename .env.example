SECRET_KEY=change-me-in-production
DEBUG=True

# Use sqlite for local development. Change to mysql when ready.
DB_ENGINE=sqlite
SQLITE_NAME=db.sqlite3

DB_NAME=payment_gateway
DB_USER=root
DB_PASSWORD=password
DB_HOST=127.0.0.1
DB_PORT=3306

# Bank communication.
# local = direct in-process simulator, tcp = normal TCP socket server.
BANK_TRANSPORT=tcp
BANK_TCP_HOST=127.0.0.1
BANK_TCP_PORT=9000
BANK_TCP_TIMEOUT_SECONDS=5
